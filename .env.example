# Space-Track.org credentials (required for conjunction/CDM data)
# Register free at: https://www.space-track.org/auth/createAccount
SPACE_TRACK_USER=your_email@example.com
SPACE_TRACK_PASSWORD=your_password

# Optional overrides
CELESTRAK_BASE_URL=https://celestrak.org
NOAA_SWPC_BASE_URL=https://services.swpc.noaa.gov

# Redis (optional - falls back to in-memory cache if not set)
REDIS_URL=redis://localhost:6379/0

# Cache TTLs (seconds)
CACHE_TTL_TLE_SECONDS=3600
CACHE_TTL_CONJUNCTION_SECONDS=1800
CACHE_TTL_SPACE_WEATHER_SECONDS=300

# Propagation
PROPAGATION_STEP_SECONDS=60
CONJUNCTION_LOOKAHEAD_DAYS=7

# Ground stations (JSON list)
# GROUND_STATIONS='[{"name":"Svalbard","lat":78.23,"lon":15.40,"elevation_m":458,"min_elevation_deg":5}]'
